# Copy to .env and fill in your keys ( .env is gitignored — never commit it )
#
#   cp .env.example .env
#
# Anthropic — recommended for animate/choreo + viewfinder vision (quality tier)
# Get an API key at https://console.anthropic.com/ (separate from Claude Pro $20/mo)
ANTHROPIC_API_KEY=

# DeepSeek — optional fallback when no Anthropic key (text-only)
# DEEPSEEK_API_KEY=

# Optional overrides
# DIRECTOR_LLM_PROVIDER=anthropic   # anthropic | deepseek | none
# DIRECTOR_QUALITY_MODEL=claude-sonnet-5   # animate refine — avoid *-max reasoning IDs
# DIRECTOR_FAST_MODEL=deepseek-v4-flash    # reserved; preview/coarse use grammar today
# DIRECTOR_MODEL=claude-sonnet-5           # legacy override for whichever provider wins
