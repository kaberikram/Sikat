# Copy to .env and fill in your keys ( .env is gitignored — never commit it )
#
#   cp .env.example .env
#
# DeepSeek — text command parsing (recommended for fuzzy natural language)
DEEPSEEK_API_KEY=

# Anthropic — viewfinder vision (Shift+mic, "look at the shot", …)
# ANTHROPIC_API_KEY=

# Optional overrides
# DIRECTOR_LLM_PROVIDER=deepseek   # deepseek | anthropic | none
# DIRECTOR_MODEL=deepseek-v4-flash
